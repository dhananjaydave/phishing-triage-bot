# Copy to .env. This bot is private - only ALLOWED_TELEGRAM_CHAT_IDS get a response.

# 1. Message @BotFather on Telegram, /newbot, copy the token here.
#    Use a SEPARATE bot from any other project - one webhook per token.
TELEGRAM_BOT_TOKEN=

# 2. Any random string - generate with:
#      python -c "import secrets; print(secrets.token_urlsafe(32))"
TELEGRAM_WEBHOOK_SECRET=

# 3. Message @userinfobot on Telegram to find your numeric chat id.
#    Comma-separate for more than one person.
ALLOWED_TELEGRAM_CHAT_IDS=

# Public URL this app is reachable at - needed to register the Telegram
# webhook. Leave as-is for local dev; set to your Render URL in production.
BASE_URL=http://localhost:8000

# Where the IOC Enrichment API (separate project/repo) is running. Leave
# unset to skip IOC enrichment entirely - heuristic checks still work.
IOC_ENRICHMENT_API_URL=
IOC_ENRICHMENT_API_KEY=
